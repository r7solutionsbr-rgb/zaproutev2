PORT=3333
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/zaproute?schema=public"

# Auth
JWT_SECRET="change_me_to_a_secure_random_string_min_32_chars"

# CORS
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# Email (Nodemailer)
EMAIL_HOST="smtp.example.com"
EMAIL_PORT=587
EMAIL_USER="user@example.com"
EMAIL_PASS="password"

# AWS S3 Compatible Storage (Cloudflare R2 / AWS S3)
R2_ACCOUNT_ID="your_account_id"
R2_ACCESS_KEY_ID="your_access_key_id"
R2_SECRET_ACCESS_KEY="your_secret_access_key"
R2_BUCKET_NAME="zaproute-bucket"

# Z-API (WhatsApp Integration)
ZAPI_INSTANCE_ID="your_instance_id"
ZAPI_TOKEN="your_token"
ZAPI_CLIENT_TOKEN="your_client_token"

# AI (Gemini)
GEMINI_API_KEY="your_gemini_api_key"
# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=

# Monitoramento (Sentry)
SENTRY_DSN=
LOG_LEVEL=info
